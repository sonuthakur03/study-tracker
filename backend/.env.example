PORT=5000
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/study-tracker
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Resend API (https://resend.com) - free 3000 emails/month
# Sign up → API Keys → Create → paste here
# Works on Render free tier (Gmail SMTP is blocked by Render)
RESEND_API_KEY=re_xxxxxxxxxxxxx

ADMIN_EMAIL=your_admin_email@gmail.com
APP_NAME=StudyTrack Nepal

# One-time seed endpoint secret (make up any random string)
SEED_SECRET=your_random_seed_secret_123
